<section id="planner">
  <div class="section-wrap">
    <p class="section-label reveal">AI Generator</p>
    <h2 class="section-title reveal">Build Your Study Plan</h2>
    <p class="section-desc reveal">Tell us your subjects and goals. Our AI will craft a personalized, week-by-week study schedule just for you.</p>
    <div class="planner-layout">
      <div class="planner-form-wrap reveal">
        <div class="form-group">
          <label>📚 Exam / Subject Name</label>
          <input type="text" id="subject-input" placeholder="e.g. Physics, Mathematics, History…">
        </div>
        <div class="form-group">
          <label>📅 Exam Date</label>
          <input type="date" id="exam-date">
        </div>
        <div class="form-group">
          <label>⏰ Daily Study Hours</label>
          <select id="study-hours">
            <option value="1">1 hour / day</option>
            <option value="2" selected>2 hours / day</option>
            <option value="3">3 hours / day</option>
            <option value="4">4+ hours / day</option>
          </select>
        </div>
        <div class="form-group">
          <label>🎓 Difficulty Level</label>
          <select id="difficulty">
            <option value="easy">Easy — Light Review</option>
            <option value="medium" selected>Medium — Balanced</option>
            <option value="hard">Hard — Intense Prep</option>
          </select>
        </div>
        <div class="form-group">
          <label>📝 Learning Style</label>
          <div class="tag-row" id="style-tags">
            <span class="tag active" data-val="visual">👁 Visual</span>
            <span class="tag" data-val="reading">📖 Reading</span>
            <span class="tag" data-val="practice">✍️ Practice</span>
            <span class="tag" data-val="audio">🎧 Audio</span>
          </div>
        </div>
        <button id="generate-btn" onclick="generatePlan()">✨ Generate My AI Study Plan</button>
      </div>
      <div>
        <div class="plan-output reveal" id="plan-output">
          <div class="plan-placeholder" id="plan-placeholder">
            <div class="ph-icon">📋</div>
            <p>Your personalized study plan will appear here after you fill in the details and click generate.</p>
          </div>
          <div class="spinner" id="spinner"><div class="spin-ring"></div></div>
          <div class="plan-result" id="plan-result">
            <h3 id="plan-title">Your Study Plan</h3>
            <div class="plan-days" id="plan-days"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

